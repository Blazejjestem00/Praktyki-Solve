const saveSwipe = async (swiperId, swipedId, action) => {
  const query = `
    INSERT INTO swipes (swiper_id, swiped_id, action)
    VALUES ($1, $2, $3)
    ON CONFLICT (swiper_id, swiped_id)
    DO UPDATE SET action = EXCLUDED.action;
  `;
  await pool.query(query, [swiperId, swipedId, action]);
};
```

```sql
const getMyMatches = async (userId) => {
  const query = `
    SELECT
        m.id AS match_id,
        m.matched_at,
        u.id AS user_id,
        u.name,
        u.age,
        u.caption,
        (
            SELECT p.photo_url
            FROM photos p
            WHERE p.user_id = u.id
            ORDER BY p.position NULLS LAST, p.id
            LIMIT 1
        ) AS main_photo
    FROM matches m
    JOIN users u ON u.id = CASE
                            WHEN m.user1_id = $1 THEN m.user2_id
                            ELSE m.user1_id
                          END
    WHERE m.user1_id = $1 OR m.user2_id = $1
    ORDER BY m.matched_at DESC;
  `;
  const result = await pool.query(query, [userId]);
  return result.rows;
};
```