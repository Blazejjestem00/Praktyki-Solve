```sql
const getUserProfile = async (userId) => {
  const query = `
    SELECT
        u.id, u.name, u.surname, u.age, u.email, u.interests,
        u.caption, u.instagram,
        COALESCE(
            json_agg(
                json_build_object(
                    'id', p.id,
                    'photo_url', p.photo_url,
                    'is_primary', p.is_primary,
                    'position', p.position
                ) ORDER BY p.position NULLS LAST, p.id
            ) FILTER (WHERE p.id IS NOT NULL),
            '[]'::json
        ) AS photos
    FROM users u
    LEFT JOIN photos p ON p.user_id = u.id
    WHERE u.id = $1
    GROUP BY u.id;
  `;
  const result = await pool.query(query, [userId]);
  return result.rows[0];
};
```

```sql
const getProfilesForSwipe = async (currentUserId) => {
  const query = `
    SELECT
        u.id,
        u.name,
        u.age,
        u.caption,
        u.interests,
        (
            SELECT p.photo_url
            FROM photos p
            WHERE p.user_id = u.id
            ORDER BY p.position NULLS LAST, p.id
            LIMIT 1
        ) AS main_photo
    FROM users u
    WHERE u.id != $1
      AND u.id NOT IN (SELECT swiped_id FROM swipes WHERE swiper_id = $1)
    ORDER BY RANDOM()
    LIMIT 10;
  `;
  const result = await pool.query(query, [currentUserId]);
  return result.rows;
};
```

